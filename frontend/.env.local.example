# Frontend Environment Configuration

# ============================================
# API Configuration
# ============================================
# Backend API URL (used by Next.js frontend to connect to the bot API)
# Default: http://localhost:8000 (when running locally)
# Change this if your API server is running on a different host/port
NEXT_PUBLIC_API_URL=http://localhost:8000

# Alternative: If deploying to production, set to your production API URL
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# TAO Staking Bot Configuration

# ============================================
# RPC Endpoints
# ============================================
# Subtensor RPC endpoint (WebSocket)
SUBTENSOR_RPC=wss://entrypoint-finney.opentensor.ai:443

# ============================================
# Wallet Configuration
# ============================================
# Your Bittensor wallet name (required for execution)
WALLET_NAME=your_wallet_name

# Your Bittensor hotkey name (required for execution)
WALLET_HOTKEY=your_hotkey_name

# ============================================
# Trading Parameters
# ============================================
# Minimum wallet stake amount (in TAO) to trigger bot action
MIN_WALLET_STAKE=30.0

# Maximum bot stake amount (in TAO) per trade
MAX_BOT_STAKE=100.0

# Minimum expected profit (in TAO) to execute a trade
MIN_EXPECTED_PROFIT=0.05

# Bot stake as ratio of wallet stake (0.0 to 1.0)
BOT_STAKE_RATIO=0.5

# Minimum TAO to keep in wallet after staking (reserve)
MIN_WALLET_RESERVE=0.02

# ============================================
# Subnet Configuration
# ============================================
# Comma-separated list of subnet IDs to monitor (e.g., "46,19,8")
MONITORED_SUBNETS=46,19,8

# ============================================
# Risk Management
# ============================================
# Maximum number of trades per day
MAX_DAILY_TRADES=50

# Maximum acceptable slippage (0.0 to 1.0, e.g., 0.05 = 5%)
MAX_SLIPPAGE=0.05

# ============================================
# Performance Settings
# ============================================
# Mempool check interval in seconds (lower = faster detection, higher CPU usage)
MEMPOOL_CHECK_INTERVAL=0.05

# Transaction timeout in seconds
TRANSACTION_TIMEOUT=30.0

# Use multiple RPC nodes for broadcasting (true/false)
USE_MULTIPLE_RPC=true

# ============================================
# Database Configuration
# ============================================
# Database connection URL
# SQLite (default): sqlite+aiosqlite:///./bot.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# ============================================
# API Server Configuration
# ============================================
# API server host (0.0.0.0 to accept connections from any interface)
API_HOST=0.0.0.0

# API server port
API_PORT=8000
